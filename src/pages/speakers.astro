---

<Base title="Speakers" description="Invited speakers at the 8th International Workshop on Flame Chemistry">
  <div class="content-body">
    <div class="page-header" style="padding-top:0;">
      <h1>Invited Speakers</h1>
      <p class="subtitle"><Ordinal n={8} /> FCWS — Kyoto 2026</p>
    </div>

    <div class="speakers-grid">
      {speakers.map(s => (
        <div class="speaker-card">
          <div class="speaker-photo-wrap">
            {s.photo
              ? <img src={s.photo} alt={s.name} loading="lazy" />
              : <div class="speaker-placeholder">
                  <span>{s.name.split(" ").map((w: string) => w[0]).join("").slice(0,2)}</span>
                </div>
            }
          </div>
          <span class="speaker-name">{s.name}</span>
          <span class="speaker-affiliation">{s.affiliation}</span>
          <span class="speaker-location">{s.location}</span>
          <span class="speaker-topic">{s.topic}</span>
        </div>
      ))}
    </div>
  </div>
</Base>

<style>
.speakers-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2rem 1.5rem;
  margin-top: 1.5rem;
  align-items: start;
}

@media (max-width: 800px) {
  .speakers-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  .speakers-grid { grid-template-columns: 1fr; }
}

.speaker-card {
  display: flex;
  flex-direction: column;
}

.speaker-photo-wrap {
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: var(--bg-tinted);
  border-bottom: 3px solid var(--blue);
}

.speaker-photo-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 20%;
  display: block;
  filter: grayscale(20%);
  transition: filter 0.25s;
}
.speaker-photo-wrap img:hover { filter: grayscale(0%); }

.speaker-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-tinted);
  color: var(--rule-heavy);
  font-family: var(--font-serif);
  font-size: 2rem;
  letter-spacing: 0.05em;
  user-select: none;
}

.speaker-name {
  font-family: var(--font-serif);
  font-size: 1rem;
  color: var(--ink);
  line-height: 1.3;
  margin-top: 0.6rem;
}

.speaker-affiliation {
  font-size: 0.8rem;
  color: var(--ink-muted);
  line-height: 1.4;
  min-height: 2.8em;
  margin-top: 0.15rem;
}

.speaker-location {
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-faint);
}

.speaker-topic {
  font-size: 0.72rem;
  color: var(--blue);
  margin-top: 0.3rem;
  border-top: 1px solid var(--rule);
  padding-top: 0.35rem;
}
</style>
