---
import Base from "../../layouts/Base.astro";
import Ordinal from "../../components/Ordinal.astro";
import { getCollection } from "astro:content";

const editions = await getCollection("archive");
editions.sort((a, b) => b.data.year - a.data.year);
---

<Base title="Archive" description="Past editions of the International Workshop on Flame Chemistry">
  <div class="content-body">
    <div class="page-header" style="padding-top:0; border-bottom:none; margin-bottom:1rem;">
      <h1>Archive</h1>
      <!-- <p class="subtitle">Past editions of the International Workshop on Flame Chemistry</p> -->
    </div>

    <ul class="archive-list">
      {editions.map((ed) => (
        <li>
          <a href={`/archive/${ed.data.year}`} class="archive-entry-link">
            <span class="archive-entry-title">
              <Ordinal n={ed.data.edition} /> edition &mdash; {ed.data.location}
              <span class="archive-entry-dates">{ed.data.dates}</span>
            </span>
            <span class="archive-entry-arrow">→</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Base>

<style>
.archive-list li {
  border: none !important;
  padding: 0.5rem 0 !important;
}
.archive-list li:first-child {
  border: none !important;
}
.archive-entry-link {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  text-decoration: none;
  color: inherit;
  gap: 1rem;
}
.archive-entry-dates {
  font-size: 0.85rem;
  color: var(--ink-muted);
  font-family: var(--font-sans);
  font-weight: 400;
  margin-left: 0.6rem;
}
.archive-entry-arrow {
  color: var(--ink-faint);
  transition: transform 0.15s ease, color 0.15s ease;
  flex-shrink: 0;
}
.archive-entry-link:hover .archive-entry-title {
  color: var(--blue);
}
.archive-entry-link:hover .archive-entry-arrow {
  transform: translateX(4px);
  color: var(--blue);
}
</style>
