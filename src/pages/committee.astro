---
import Base from "../layouts/Base.astro";
import Ordinal from "../components/Ordinal.astro";

const organizing = [
  {
    name: "Matteo Pelucchi",
    affiliation: "Politecnico di Milano",
    country: "Italy",
    email: "matteo.pelucchi@polimi.it",
    scholar: "https://scholar.google.com/citations?hl=it&user=_pQycK8AAAAJ&view_op=list_works&sortby=pubdate",
    website: "https://www.creckmodeling.polimi.it/team/matteo-pelucchi/",
    photo: "/images/committee/matteo-pelucchi.jpg",
  },
  {
    name: "Bin Yang",
    affiliation: "Tsinghua University",
    country: "China",
    email: "byang@tsinghua.edu.cn",
    scholar: "https://scholar.google.com/citations?user=jX4VmJEAAAAJ&hl=zh-CN",
    website: "https://www.cce.tsinghua.edu.cn/en/info/1005/2211.htm",
    photo: "/images/committee/bin-yang.jpg",
  },
  {
    name: "Brandon Rotavera",
    affiliation: "University of Georgia",
    country: "USA",
    email: "rotavera@uga.edu",
    scholar: "https://scholar.google.com/citations?user=MDVL2x8AAAAJ&hl=en",
    website: "https://rotavera.uga.edu/",
    photo: "/images/committee/brandon-rotavera.jpg",
  },
  {
    name: "Feng Zhang",
    affiliation: "University of Science and Technology",
    country: "China",
    email: "feng2011@ustc.edu.cn",
    scholar: "https://scholar.google.com/citations?user=FU1fn2EAAAAJ&hl=zh-CN",
    website: "http://staff.ustc.edu.cn/~feng2011/people/fengzhang.html",
    photo: "/images/committee/feng-zhang.png",
  },
  {
    name: "Andrea Comandini",
    affiliation: "CNRS Orléans",
    country: "France",
    email: "andrea.comandini@cnrs-orleans.fr",
    scholar: null,
    website: "https://shockwaves-icare.cnrs.fr/erc_fun-pm/cv-ac/",
    photo: "/images/committee/andrea-comandini.jpg",
  },
  {
    name: "Liming Cai",
    affiliation: "Tongji University",
    country: "China",
    email: "lcai@tongji.edu.cn",
    scholar: "https://scholar.google.com/citations?user=VstEICkAAAAJ&hl=en",
    website: null,
    photo: "/images/committee/liming-cai.jpg",
  },
];

const founding = [
  {
    name: "Yiguang Ju",
    affiliation: "Department of Mechanical & Aerospace Engineering, Princeton University",
    country: "USA",
    photo: "/images/committee/yiguang-ju.jpg",
  },
  {
    name: "Hai Wang",
    affiliation: "Department of Mechanical Engineering, Stanford University",
    country: "USA",
    photo: "/images/committee/hai-wang.webp",
  },
];

const advisory = [
  {
    name: "Nils Hansen",
    affiliation: "Sandia National Laboratories",
    country: "USA",
    email: "nhansen@sandia.gov",
    scholar: null,
    website: null,
    photo: "/images/committee/nils-hansen.jpg",
  },
  {
    name: "Stephen J. Klippenstein",
    affiliation: "Argonne National Laboratory",
    country: "USA",
    email: "sjk@anl.gov",
    scholar: null,
    website: null,
    photo: "/images/committee/stephen-klippenstein.jpg",
  },
];
---

<Base title="Committee" description="Organizing and Advisory Committee of the 8th FCWS">
  <div class="content-body">
    <div class="page-header" style="padding-top:0;">
      <h1>Committee</h1>
      <p class="subtitle"><Ordinal n={8} /> International Workshop on Flame Chemistry — Kyoto 2026</p>
    </div>

    <section>
      <div class="section-rule">
        <h2>Organizing Committee</h2>
      </div>
      <div class="people-grid">
        {organizing.map(p => (
          <div class="person-card">
            <div class="person-photo-wrap">
              <img src={p.photo} alt={p.name} loading="lazy" />
            </div>
            <div class="person-info">
              <span class="person-name">{p.name}</span>
              <span class="person-affiliation">{p.affiliation}</span>
              <span class="person-country">{p.country}</span>
              <div class="person-links">
                {p.email && (
                  <a href={`mailto:${p.email}`} class="person-icon-link" title={p.email} aria-label={`Email ${p.name}`}>
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="2" y="4" width="20" height="16" rx="2"/>
                      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                    </svg>
                  </a>
                )}
                {p.scholar && (
                  <a href={p.scholar} target="_blank" rel="noopener" class="person-icon-link" title="Google Scholar" aria-label={`Google Scholar profile of ${p.name}`}>
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.838 3.94A8 8 0 0 1 12 10a8 8 0 0 1 7.162 3.44L24 9.5z"/>
                    </svg>
                  </a>
                )}
                {p.website && (
                  <a href={p.website} target="_blank" rel="noopener" class="person-icon-link" title="Website" aria-label={`Website of ${p.name}`}>
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"/>
                      <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                    </svg>
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section style="margin-top:3rem;">
      <div class="section-rule">
        <h2>Advisory Committee</h2>
      </div>
      <div class="people-grid">
        {advisory.map(p => (
          <div class="person-card">
            <div class="person-photo-wrap">
              <img src={p.photo} alt={p.name} loading="lazy" />
            </div>
            <div class="person-info">
              <span class="person-name">{p.name}</span>
              <span class="person-affiliation">{p.affiliation}</span>
              <span class="person-country">{p.country}</span>
              <div class="person-links">
                {p.email && (
                  <a href={`mailto:${p.email}`} class="person-icon-link" title={p.email} aria-label={`Email ${p.name}`}>
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="2" y="4" width="20" height="16" rx="2"/>
                      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                    </svg>
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
    <section style="margin-top:3rem;">
      <div class="section-rule">
        <h2>Founding Members</h2>
      </div>
      <div class="people-grid">
        {founding.map(p => (
          <div class="person-card">
            <div class="person-photo-wrap">
              <img src={p.photo} alt={p.name} loading="lazy" />
            </div>
            <div class="person-info">
              <span class="person-name">{p.name}</span>
              <span class="person-affiliation">{p.affiliation}</span>
              <span class="person-country">{p.country}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

  </div>
</Base>

<style>
.people-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 2rem 1.5rem;
  margin-top: 1.5rem;
}

.person-card {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  border-bottom: 1px solid var(--blue);
  padding-bottom: 0.75rem;
}

.person-info {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
  flex: 1;
}

.person-photo-wrap {
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: var(--bg-tinted);
}

.person-photo-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
  filter: grayscale(20%);
  transition: filter 0.25s;
}

.person-photo-wrap img:hover {
  filter: grayscale(0%);
}


.person-name {
  font-family: var(--font-serif);
  font-size: 1rem;
  color: var(--ink);
  line-height: 1.3;
}

.person-affiliation {
  font-size: 0.8rem;
  color: var(--ink-muted);
  line-height: 1.4;
}

.person-country {
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-faint);
}

.person-links {
  display: flex;
  gap: 0.75rem;
  margin-top: auto;
  padding-top: 0.4rem;
}
.person-icon-link {
  display: inline-flex;
  align-items: center;
  color: var(--ink-faint);
  text-decoration: none;
  border: none;
  transition: color 0.15s;
}
.person-icon-link:hover {
  color: var(--blue);
}
</style>
